# ========================================
# KABRAK BACKEND - Configuration
# ========================================

# ========================================
# BASE DE DONNÉES LOCALE (Magasin)
# ========================================
DATABASE_URL="postgresql://kabrak:password@localhost:5432/kabrak_local"

# ========================================
# SERVEUR CLOUD (Hetzner)
# ========================================
CLOUD_API_URL="https://kabrak.ton-domaine.com/api"
CLOUD_API_KEY="your-secret-api-key"

# ========================================
# APPLICATION
# ========================================
PORT=3000
NODE_ENV="development"

# ========================================
# SYNCHRONISATION
# ========================================
SYNC_ENABLED=true
SYNC_INTERVAL=300000  # 5 minutes (en millisecondes)
SYNC_RETRY_ATTEMPTS=3
SYNC_RETRY_DELAY=60000  # 1 minute

# ========================================
# IMPORT CSV
# ========================================
MAX_IMPORT_SIZE=50000  # Nombre max de produits par import
IMPORT_BATCH_SIZE=1000  # Traiter par lots de 1000

# ========================================
# CACHE (optionnel - Redis)
# ========================================
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD=""
CACHE_TTL=3600  # 1 heure

# ========================================
# SÉCURITÉ
# ========================================
JWT_SECRET="your-super-secret-jwt-key-change-this"
JWT_EXPIRATION="24h"

# ========================================
# CORS (Frontend Next.js)
# ========================================
CORS_ORIGIN="http://localhost:3001"  # URL du frontend

# ========================================
# LOGS
# ========================================
LOG_LEVEL="debug"  # "error", "warn", "info", "debug"
